@model TypeCompte

<h3>Confirmer la suppression ?</h3>

<div>
    <h3>@Model.Libelle</h3>
</div>

<form asp-action="DeleteTypeCompteConfirmation" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Oui, supprimer
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Annuler
    </a>
</form>