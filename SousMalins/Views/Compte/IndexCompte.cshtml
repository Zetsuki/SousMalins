@model List<Compte>
@{
    ViewData["Title"] = "Liste des comptes";
}

<div class="d-flex flex-column">
    <div class="d-flex align-items-center justify-content-between">
        <section>
            <h2 class="fw-bold">Comptes</h2>
            <p class="text-secondary">Gérez vos comptes et suivez leurs soldes.</p>
        </section>
        <a class="btn btn-primary" asp-area="" asp-controller="Compte" asp-action="CreateCompte">+ Ajouter un compte</a>
    </div>

    <!-- TODO replace mocks-->
    <div class="d-flex gap-5">

        <div class="d-flex flex-column align-items-center w-50 rounded-4 shadow border border-2 border-primary py-2">
            <p class="mb-1 mt-2">Compte Courant</p>
            <p class="text-secondary mb-1">Compte Courant</p>
            <p class="fw-bold fs-5 mb-1">1250,00 €</p>
            <div class="d-inline-flex align-items-center gap-2 rounded-4 px-3 py-1 mb-2">
                <p class="m-0 text-success">↑ +200,00 €</p>
                <p class="text-secondary m-0">ce mois</p>
            </div>
        </div>

        <div class="d-flex flex-column align-items-center w-50 rounded-4 shadow py-2">
            <p class="mb-1 mt-2">Livret A</p>
            <p class="text-secondary mb-1">Epargne</p>
            <p class="fw-bold fs-5 mb-1">2800,00 €</p>
            <div class="d-inline-flex align-items-center gap-2 rounded-4 px-3 py-1 mb-2">
                <p class="m-0 text-success">↑ +80,00 €</p>
                <p class="text-secondary m-0">ce mois</p>
            </div>
        </div>

        <div class="d-flex flex-column align-items-center w-50 rounded-4 shadow py-2">
            <p class="mb-1 mt-2">Carte Visa</p>
            <p class="text-secondary mb-1">Carte bancaire</p>
            <p class="fw-bold fs-5 mb-1">-120,00 €</p>
            <div class="d-inline-flex align-items-center gap-2 rounded-4 px-3 py-1 mb-2">
                <p class="m-0 text-danger">↓ -60,00 €</p>
                <p class="text-secondary m-0">ce mois</p>
            </div>
        </div>

        <div class="d-flex flex-column align-items-center w-50 rounded-4 shadow py-2">
            <p class="mb-1 mt-2">Compte Joint</p>
            <p class="text-secondary mb-1">Compte courant</p>
            <p class="fw-bold fs-5 mb-1">3450,00 €</p>
            <div class="d-inline-flex align-items-center gap-2 rounded-4 px-3 py-1 mb-2">
                <p class="m-0 text-success">↑ +150,00 €</p>
                <p class="text-secondary m-0">ce mois</p>
            </div>
        </div>

    </div>

    <!-- TODO replace mocks-->
    <div>

    </div>
</div>
